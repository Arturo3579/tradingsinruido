---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const title = "Blog";
const description = "Todos los artículos de Trading Sin Ruido: finanzas personales, inversión para principiantes, estrategias de trading y psicología del mercado.";
---

<BaseLayout title={title} description={description} breadcrumbs={[{name: "Inicio", url: "/"}, {name: "Blog", url: "/blog"}]}>
  <div class="page-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Inicio</a><span class="sep">/</span><span class="current">Blog</span>
    </nav>
    <header class="page-header">
      <h1 class="page-title">Blog</h1>
      <p class="page-lead">Artículos prácticos sobre finanzas personales, inversión y trading. Sin relleno, sin promesas absurdas. Solo lo que puedes aplicar mañana mismo.</p>
    </header>

    <section class="post-list">
      {sortedPosts.length === 0 && (
        <p style="color: var(--color-text-muted);">No hay artículos publicados aún.</p>
      )}

      {sortedPosts.map((post) => (
        <article class="post-card">
          {post.data.image && (
            <a href={`/blog/${post.id}`}>
              <img src={post.data.image} alt={post.data.title} class="post-card-image" loading="lazy" />
            </a>
          )}
          <div class="post-card-body">
            <h3 class="post-card-title">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h3>
            <div class="post-card-meta">
              <time datetime={post.data.date.toISOString()}>
                {new Intl.DateTimeFormat("es-ES", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                }).format(post.data.date)}
              </time>
              <span class="post-card-category">{post.data.category}</span>
            </div>
            <p class="post-card-description">{post.data.description}</p>
            <a href={`/blog/${post.id}`} class="read-more">
              Leer más &rarr;
            </a>
          </div>
        </article>
      ))}
    </section>
  </div>
</BaseLayout>
