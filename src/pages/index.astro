---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Inicio" description="Blog sobre trading, inversión y educación financiera. Aprende a operar sin ruido.">
  <section class="post-list">
    <h2 class="section-title">Últimos artículos</h2>

    {sortedPosts.length === 0 && (
      <p style="color: var(--color-text-muted);">No hay artículos publicados aún.</p>
    )}

    {
      sortedPosts.map((post) => (
        <article class="post-card">
          <h3 class="post-card-title">
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
          </h3>
          <div class="post-card-meta">
            <time datetime={post.data.date.toISOString()}>
              {new Intl.DateTimeFormat("es-ES", {
                year: "numeric",
                month: "long",
                day: "numeric",
              }).format(post.data.date)}
            </time>
            <span class="post-card-category">{post.data.category}</span>
          </div>
          <p class="post-card-description">{post.data.description}</p>
          <a href={`/blog/${post.id}`} class="read-more">
            Leer más &rarr;
          </a>
        </article>
      ))
    }
  </section>
</BaseLayout>
