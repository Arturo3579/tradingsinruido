---
export interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Trading Sin Ruido" />
    {image && <meta property="og:image" content={image} />}

    <!-- PEGAR SCRIPT DE GOOGLE ADSENSE AQUÍ -->

    <title>{title} | Trading Sin Ruido</title>

    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-title">Trading Sin Ruido</a>
        <nav class="site-nav">
          <a href="/">Inicio</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Trading Sin Ruido. Todos los derechos reservados.</p>
        <p><a href="/">Inicio</a></p>
      </div>
    </footer>
  </body>
</html>
