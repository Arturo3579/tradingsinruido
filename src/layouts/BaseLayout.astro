---
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  image?: string;
  breadcrumbs?: { name: string; url: string }[];
}

const { title, description, image, breadcrumbs } = Astro.props;

const siteUrl = "https://www.tradingsinruido.com";

// Schema.org Person (author)
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Arturo",
  "url": `${siteUrl}/sobre-mi`,
  "jobTitle": "Trader independiente y creador de contenido financiero",
  "description": "Creador de Trading Sin Ruido. Experiencia real en trading, inversión y gestión personal de finanzas desde 2021.",
  "email": "mailto:thor19daniel@gmail.com",
  "sameAs": []
};

// Schema.org BreadcrumbList (if breadcrumbs provided)
const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((crumb, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": crumb.name,
    "item": crumb.url.startsWith("http") ? crumb.url : `${siteUrl}${crumb.url}`
  }))
} : null;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Trading Sin Ruido" />
    {image && <meta property="og:image" content={image} />}

    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6120255629055260" crossorigin="anonymous"></script>

    <!-- Google Analytics 4 (reemplaza G-XXXXXXXXXX con tu ID de medición real) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <!-- PEGAR META TAG DE GOOGLE SEARCH CONSOLE AQUÍ -->

    <!-- Schema.org: Person (author) -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- Schema.org: BreadcrumbList -->
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}

    <title>{title} | Trading Sin Ruido</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-title">
          <img src="/images/logo.svg" alt="Trading Sin Ruido" class="site-logo" width="40" height="36" />
          <span class="site-title-text">Trading Sin Ruido</span>
        </a>
        <nav class="site-nav">
          <a href="/">Inicio</a>
          <a href="/blog">Blog</a>
          <a href="/herramientas">Herramientas</a>
          <a href="/sobre-mi">Sobre Mí</a>
          <a href="/contacto">Contacto</a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Cambiar modo oscuro/claro">
            <span class="theme-icon light">☀️</span>
            <span class="theme-icon dark">🌙</span>
          </button>
        </nav>
      </div>
    </header>

    <script>
      // Check for saved theme preference or default to 'light'
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'light';
      };

      const setTheme = (theme) => {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
      };

      // Initialize theme
      const currentTheme = getTheme();
      setTheme(currentTheme);

      // Toggle button click handler
      document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('theme-toggle');
        if (toggleBtn) {
          toggleBtn.addEventListener('click', () => {
            const currentTheme = getTheme();
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            setTheme(newTheme);
          });
        }
      });
    </script>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <div class="footer-brand"><a href="/">Trading Sin Ruido</a></div>
          <p class="footer-desc">Centro de recursos sobre finanzas personales, inversión y trading. Aprende a manejar tu dinero sin ruido.</p>
        </div>
        <div class="footer-links">
          <h4>Navegación</h4>
          <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/herramientas">Herramientas</a></li>
            <li><a href="/sobre-mi">Sobre Mí</a></li>
            <li><a href="/contacto">Contacto</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Legal y Transparencia</h4>
          <ul>
            <li><a href="/privacidad">Política de Privacidad</a></li>
            <li><a href="/cookies">Política de Cookies</a></li>
            <li><a href="/terminos">Términos de Uso</a></li>
            <li><a href="/politica-editorial">Política Editorial</a></li>
            <li><a href="/metodologia">Metodología</a></li>
            <li><a href="/correcciones">Correcciones</a></li>
          </ul>
        </div>
      </div>
      <div class="container footer-bottom">
        <p>&copy; {new Date().getFullYear()} Trading Sin Ruido. Todos los derechos reservados.</p>
        <p>Este sitio contiene enlaces de afiliados y publicidad. Todo el contenido es educativo. No es asesoramiento financiero.</p>
      </div>
    </footer>
  </body>
</html>
